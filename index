  if (!t || !n) { alert('Ticker and Name required'); return; }
  if (funds.find(f => f.ticker === t)) { alert('Fund already exists'); return; }
 
  const newFund = { ticker:t, name:n, sleeve:s, benchmark:b, yield:y, mer:m, returns:{}, overrides:{}, isLoading:true };
  funds.push(newFund);
  ['add-ticker','add-name','add-benchmark','add-yield','add-mer'].forEach(id => document.getElementById(id).value='');
  renderAll();
  // Fetch live data
  fetchYahooFund(newFund).then(data => {
