function renderCustomPortfolio() {
  const container = document.getElementById('custom-holdings');
  container.innerHTML = customHoldings.map((h,i) => `
    <div style="display:flex;gap:8px;align-items:center;margin-bottom:6px">
      <select onchange="customHoldings[${i}].ticker=this.value;updateCustomTotal()" style="flex:1;padding:5px 8px;border:1px solid var(--border);border-radius:5px;font-family:inherit;font-size:12px;">
        <option value="">-- Select Fund --</option>
        ${funds.map(f=>`<option value="${f.ticker}" ${h.ticker===f.ticker?'selected':''}>${f.ticker} — ${f.name}</option>`).join('')}
      </select>
      <input type="number" value="${h.weight||''}" placeholder="Weight%" min="0" max="100" step="0.5"
        onchange="customHoldings[${i}].weight=parseFloat(this.value)||0;updateCustomTotal()"
        style="width:80px;padding:5px 8px;border:1px solid var(--border);border-radius:5px;font-family:'IBM Plex Mono';font-size:12px;">
      <button class="btn-xs btn-ghost" onclick="customHoldings.splice(${i},1);renderPortfolios()">✕</button>
    </div>`).join('');
  updateCustomTotal();
}
function addCustomRow() { customHoldings.push({ticker:'',weight:0}); renderPortfolios(); }
function updateCustomTotal() {
  const total = customHoldings.reduce((a,h)=>a+(h.weight||0),0);
  const bar = document.getElementById('custom-total-bar');
  const label = document.getElementById('custom-total-bar-label');
  if (bar) {
    bar.style.width = Math.min(total, 100) + '%';
    bar.style.background = Math.abs(total-100)<0.1 ? 'var(--pos)' : total > 100 ? 'var(--neg)' : 'var(--gold)';
  }
  if (label) {
    const cls = Math.abs(total-100)<0.1 ? 'ok' : total>100 ? 'over' : 'under';
    label.className = `weight-total ${cls}`;
    label.textContent = `Total: ${total.toFixed(1)}%`;
  }
}
function calcCustomPortfolio() {
  const valid = customHoldings.filter(h => h.ticker && h.weight > 0);
  if (valid.length === 0) return;
  const metrics = calcBlended(valid);
  const res = document.getElementById('custom-result');
  res.style.display = 'block';
  res.innerHTML = `<div style="background:var(--navy);border-radius:6px;padding:10px 14px;display:flex;gap:12px;flex-wrap:wrap">
    ${[['YTD',metrics.ytd],['1Y',metrics['1y']],['3Y Ann',metrics['3y']],['Yield',metrics.yield],['MER',metrics.mer]].map(([l,v])=>`
      <div style="text-align:center">
        <div style="font-size:9px;color:var(--gold);text-transform:uppercase;letter-spacing:0.8px;font-weight:600">${l}</div>
        <div style="font-family:'IBM Plex Mono';font-size:14px;font-weight:700;color:white">${v!=null?(v>0?'+':'')+v.toFixed(2)+'%':'—'}</div>
      </div>`).join('')}
  </div>`;
}
 
// ═══════════════════════════════════════════════════════════════════
//  BENCHMARK TAB
// ═══════════════════════════════════════════════════════════════════
function renderBenchmark() {
  const period = document.getElementById('bench-period').value;
  const sleeveF = document.getElementById('bench-sleeve').value;
  const sortMode = document.getElementById('bench-sort').value;
 
  let data = funds.filter(f => !sleeveF || f.sleeve === sleeveF);
 
  // Build chart data
  let rows = data.map(f => {
    const fundRet = getVal(f, period);
    const bench = BENCHMARKS[f.benchmark] || {};
    const benchRet = bench[period] ?? null;
    const alpha = fundRet != null && benchRet != null ? fundRet - benchRet : null;
    return { f, fundRet, benchRet, alpha };
  });
 
  if (sortMode === 'alpha_desc') rows.sort((a,b) => (b.alpha??-99)-(a.alpha??-99));
  else if (sortMode === 'alpha_asc') rows.sort((a,b) => (a.alpha??-99)-(b.alpha??-99));
  else rows.sort((a,b) => (b.fundRet??-99)-(a.fundRet??-99));
 
  const maxVal = Math.max(...rows.map(r => Math.abs(r.fundRet ?? 0)), ...rows.map(r => Math.abs(r.benchRet ?? 0)), 0.1);
 
  const chart = document.getElementById('bench-chart');
  chart.innerHTML = `
    <div style="display:flex;align-items:center;gap:16px;margin-bottom:14px;font-size:10.5px;">
      <span style="display:flex;align-items:center;gap:5px"><span style="width:20px;height:6px;background:var(--navy);border-radius:2px;display:inline-block"></span> Fund Return</span>
      <span style="display:flex;align-items:center;gap:5px"><span style="width:2px;height:14px;background:var(--navy);border-radius:1px;display:inline-block"></span> Benchmark</span>
      <span style="display:flex;align-items:center;gap:5px;color:var(--pos)">■ Positive Alpha</span>
      <span style="display:flex;align-items:center;gap:5px;color:var(--neg)">■ Negative Alpha</span>
    </div>
    ${rows.map(r => {
      const pct = (r.fundRet ?? 0) / maxVal * 95;
      const benchPct = r.benchRet != null ? r.benchRet / maxVal * 95 : null;
      const col = r.alpha != null ? (r.alpha >= 0 ? 'var(--pos)' : 'var(--neg)') : 'var(--navy)';
      return `<div class="bar-row">
        <div class="bar-name">${r.f.name.length > 28 ? r.f.name.slice(0,27)+'…' : r.f.name}</div>
        <div class="bar-track" style="position:relative">
          <div class="bar-fill" style="width:${Math.max(pct,0)}%;background:${col};opacity:0.85"></div>
          ${benchPct != null ? `<div class="bar-bench-line" style="left:${benchPct}%"></div>` : ''}
        </div>
        <div class="bar-val" style="color:${r.fundRet>0?'var(--pos)':r.fundRet<0?'var(--neg)':'var(--text-muted)'}">${fmtPctPlain(r.fundRet)}</div>
        <div class="bar-val" style="color:var(--text-muted)">${fmtPctPlain(r.benchRet)}</div>
        <div class="bar-val" style="color:${r.alpha>0?'var(--pos)':r.alpha<0?'var(--neg)':'var(--text-muted)'}">${fmtPctPlain(r.alpha)}</div>
      </div>`;
    }).join('')}
    <div style="display:grid;grid-template-columns:150px 1fr 60px 60px 60px;gap:10px;font-size:10px;color:var(--text-muted);margin-top:6px;padding-top:6px;border-top:1px solid var(--border-light)">
      <div></div><div></div><div style="text-align:right">Fund</div><div style="text-align:right">Bench</div><div style="text-align:right">Alpha</div>
    </div>`;
}
 
