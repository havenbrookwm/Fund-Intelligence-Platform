function fmtPct(v, decimals=2) {
  if (v == null || v === '') return '<span class="na-val">—</span>';
  const fv = parseFloat(v);
  if (isNaN(fv)) return '<span class="na-val">—</span>';
  const cls = fv > 0 ? 'pos-val' : fv < 0 ? 'neg-val' : '';
  const sign = fv > 0 ? '+' : '';
  return `<span class="${cls}">${sign}${fv.toFixed(decimals)}%</span>`;
}
 
function fmtPctPlain(v, decimals=2) {
  if (v == null || v === '') return '—';
  const fv = parseFloat(v);
  if (isNaN(fv)) return '—';
  const sign = fv > 0 ? '+' : '';
  return `${sign}${fv.toFixed(decimals)}%`;
}
 
