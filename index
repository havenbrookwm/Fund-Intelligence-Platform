function calcBlended(holdings) {
  const keys = ['ytd','1y','3y','yield','mer'];
  const result = {};
  keys.forEach(k => {
    let total = 0, totalWeight = 0;
    holdings.forEach(h => {
      const f = funds.find(fd => fd.ticker === h.ticker);
      if (!f) return;
      const v = getVal(f, k);
      if (v == null) return;
      total += v * h.weight;
      totalWeight += h.weight;
    });
    result[k] = totalWeight > 0 ? total / totalWeight : null;
  });
  return result;
}
 
