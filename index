// ═══════════════════════════════════════════════════════════════════
//  SUBSTITUTE FUND (Claude API)
// ═══════════════════════════════════════════════════════════════════
async function openSuggestFund(ticker) {
  const container = document.getElementById(`suggest-${ticker}`);
  if (!container) return;
  container.innerHTML = `<div class="suggest-panel"><span class="spinner"></span> Asking Claude for substitutes…</div>`;
 
  const fund = funds.find(f => f.ticker === ticker);
  if (!fund) return;
 
  const fundList = funds.map(f => `${f.ticker}: ${f.name} (${f.sleeve}, Yield: ${f.yield}%, Bench: ${f.benchmark})`).join('\n');
 
  try {
    const response = await fetch('https://api.anthropic.com/v1/messages', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        model: 'claude-sonnet-4-20250514',
        max_tokens: 1000,
        system: `You are a Canadian ETF/fund analyst at Havenbrook Wealth Management. 
Given a fund, suggest 3 comparable substitute funds (ETFs or mutual funds, ideally Canadian-listed).
Return ONLY a JSON array of objects with: ticker, name, reason (max 25 words), yieldEst (number), mer (number).
No preamble, no markdown backticks, no extra text.`,
        messages: [{
          role: 'user',
          content: `Fund to replace: ${fund.ticker} — ${fund.name}
Sleeve: ${fund.sleeve}
Benchmark: ${fund.benchmark}
Yield: ${fund.yield}%
MER: ${fund.mer}%
 
Current platform funds (avoid suggesting these):
${fundList}
 
Suggest 3 comparable substitutes.`
        }]
      })
    });
 
    const data = await response.json();
    const text = data?.content?.find(c => c.type === 'text')?.text || '[]';
    let suggestions;
    try { suggestions = JSON.parse(text.replace(/```json|```/g,'')); }
    catch(e) { suggestions = []; }
 
    if (!suggestions.length) throw new Error('No suggestions returned');
 
    container.innerHTML = `<div class="suggest-panel">
      <div style="font-size:11px;font-weight:600;color:var(--navy);margin-bottom:8px">Substitute Suggestions for ${ticker}</div>
      ${suggestions.map(s => `
        <div class="suggest-result">
          <div><span class="suggest-ticker">${s.ticker}</span> — ${s.name}</div>
          <div class="suggest-reason">${s.reason}</div>
          <div style="font-size:10px;color:var(--text-muted);margin-top:2px">
            Est. Yield: ${s.yieldEst != null ? s.yieldEst.toFixed(1)+'%' : '—'} · MER: ${s.mer != null ? s.mer.toFixed(2)+'%' : '—'}
          </div>
        </div>`).join('')}
    </div>`;
  } catch(e) {
    container.innerHTML = `<div class="suggest-panel" style="color:var(--neg);font-size:11px">Unable to load suggestions: ${e.message}</div>`;
  }
}
 
