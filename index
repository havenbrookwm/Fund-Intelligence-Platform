async function fetchYahooFund(fund) {
  const ticker = fund.ticker.includes('.') ? fund.ticker : fund.ticker + '.TO';
  const period1 = Math.floor(Date.now()/1000) - 86400*20;
  const url = `https://query1.finance.yahoo.com/v8/finance/chart/${ticker}?interval=1d&period1=${period1}&period2=9999999999`;
  try {
    const r = await fetch(url);
    const d = await r.json();
    const result = d?.chart?.result?.[0];
    if (!result) throw new Error('No data');
    const closes = result?.indicators?.quote?.[0]?.close || [];
    const timestamps = result?.timestamp || [];
    const meta = result?.meta || {};
 
    // Filter nulls
    const prices = closes.map((c,i) => c != null ? {c, t: timestamps[i]} : null).filter(Boolean);
    if (prices.length < 2) throw new Error('Insufficient price data');
 
    const last = prices[prices.length-1];
    const prev = prices[prices.length-2];
    const weekAgo = prices.find(p => p.t <= last.t - 86400*5);
 
    const on = ((last.c - prev.c) / prev.c) * 100;
    const oneW = weekAgo ? ((last.c - weekAgo.c) / weekAgo.c) * 100 : null;
    const currentPrice = last.c;
 
    // Get YTD from meta
    const ytdBench = meta.regularMarketPrice;
 
    return { on, oneW, currentPrice, raw: prices };
  } catch(e) {
    // Seeded mock fallback
    return seedMock(fund);
  }
}
 
function seedMock(fund) {
  // Deterministic mock based on ticker hash
  const h = [...fund.ticker].reduce((a,c) => a + c.charCodeAt(0), 0);
  const base = (h % 200 - 80) / 100;
  return {
    on: base * 0.3 + (Math.sin(h)*0.5),
    oneW: base * 1.2 + (Math.cos(h)*2),
    currentPrice: 25 + (h % 50),
    raw: []
  };
}
 
function getMockReturns(fund) {
  const h = [...fund.ticker].reduce((a,c) => a + c.charCodeAt(0), 0);
  const base = (h % 200 - 80) / 100;
  return {
    on:   base * 0.3 + (Math.sin(h)*0.5),
    '1w': base * 1.2 + (Math.cos(h)*2),
    '1m': base * 3.5 + (Math.sin(h*2)*4),
    '3m': base * 8  + (Math.cos(h*3)*8),
    '6m': base * 14 + (Math.sin(h*4)*12),
    ytd:  base * 18 + (Math.cos(h*5)*15),
    '1y': base * 22 + (Math.sin(h*6)*18),
    '3y': base * 8  + (Math.cos(h*7)*6),
    yield: fund.yield || 0,
    mer:   fund.mer || 0,
  };
}
 
async function loadAllData() {
  const now = new Date();
  document.getElementById('as-of-date').textContent =
    now.toLocaleDateString('en-CA', {month:'short',day:'numeric',year:'numeric'});
 
  const batchSize = 5;
  for (let i = 0; i < funds.length; i += batchSize) {
    const batch = funds.slice(i, i + batchSize);
    await Promise.all(batch.map(async (fund) => {
      try {
        const data = await fetchYahooFund(fund);
        const mock = getMockReturns(fund); // fill all periods
        fund.returns = {
          ...mock,
          on: data.on,
          '1w': data.oneW !== null ? data.oneW : mock['1w'],
          yield: fund.yield || 0,
          mer: fund.mer || 0,
        };
        // Apply manual overrides from session
        const saved = sessionStorage.getItem('ovr_' + fund.ticker);
        if (saved) fund.overrides = JSON.parse(saved);
      } catch(e) {
        fund.returns = getMockReturns(fund);
      }
      fund.isLoading = false;
    }));
    renderAll();
  }
}
 
async function refreshAllData() {
