function applyOverride(ticker) {
  const fund = funds.find(f => f.ticker === ticker);
  if (!fund) return;
  const keys = ['ytd','1y','3y','yield','mer'];
  keys.forEach(k => {
    const el = document.getElementById(`ovr_${ticker}_${k}`);
    if (el && el.value !== '') {
      fund.overrides[k] = parseFloat(el.value);
    }
  });
  sessionStorage.setItem('ovr_' + ticker, JSON.stringify(fund.overrides));
  renderAll();
}
 
function clearOverride(ticker) {
  const fund = funds.find(f => f.ticker === ticker);
  if (!fund) return;
  fund.overrides = {};
