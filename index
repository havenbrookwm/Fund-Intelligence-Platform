function openPDFModal() {
  document.getElementById('pdf-modal').classList.add('open');
}
function closePDFModal() {
  document.getElementById('pdf-modal').classList.remove('open');
  document.getElementById('pdf-status').textContent = '';
  document.getElementById('pdf-generate-btn').disabled = false;
  document.getElementById('pdf-generate-btn').textContent = 'Generate PDF';
}
 
function buildPDFPayload() {
  const sleeveFilter = document.getElementById('pdf-sleeve').value || null;
  const sections = [];
  if (document.getElementById('pdf-s-cover').checked) sections.push('cover');
  if (document.getElementById('pdf-s-cum').checked) sections.push('cumulative');
  if (document.getElementById('pdf-s-cal').checked) sections.push('calYear');
  if (document.getElementById('pdf-s-port').checked) sections.push('portfolios');
  if (document.getElementById('pdf-s-bench').checked) sections.push('benchmark');
 
  const filteredFunds = sleeveFilter ? funds.filter(f => f.sleeve === sleeveFilter) : funds;
 
  const fundsPayload = filteredFunds.map(f => ({
    ticker: f.ticker,
    name: f.name,
    sleeve: f.sleeve,
    benchmark: f.benchmark,
    returns: {
      on: getVal(f,'on'),
      '1w': getVal(f,'1w'),
      '1m': getVal(f,'1m'),
      '3m': getVal(f,'3m'),
      '6m': getVal(f,'6m'),
      ytd: getVal(f,'ytd'),
      '1y': getVal(f,'1y'),
      '3y': getVal(f,'3y'),
      yield: f.yield,
      mer: f.mer,
    },
    calYear: CAL_YEAR_DATA[f.ticker] || {},
  }));
 
  const portfoliosPayload = PORTFOLIOS.map(p => {
    const metrics = calcBlended(p.holdings);
    return {
      name: p.name,
      metrics: { ytd: metrics.ytd, oneY: metrics['1y'], threeY: metrics['3y'], yield: metrics.yield, mer: metrics.mer },
      holdings: p.holdings.map(h => ({ ticker: h.ticker, weight: h.weight })),
    };
  });
 
  return {
    title: document.getElementById('pdf-title').value,
    preparedFor: document.getElementById('pdf-client').value,
    asOfDate: new Date().toLocaleDateString('en-CA', {month:'long',day:'numeric',year:'numeric'}),
    funds: fundsPayload,
    portfolios: portfoliosPayload,
    benchmarks: BENCHMARKS,
    sections,
    sleeveFilter: sleeveFilter ? [sleeveFilter] : null,
    periods: ['ON','1W','1M','3M','6M','YTD','1Y','3Y Ann','Yield','MER'],
    years: [2024,2023,2022,2021,2020,2019,2018,2017,2016,2015],
  };
}
 
async function generatePDF() {
  const btn = document.getElementById('pdf-generate-btn');
  const status = document.getElementById('pdf-status');
  btn.disabled = true;
  btn.innerHTML = '<span class="spinner"></span> Generating…';
  status.textContent = 'Building report data…';
 
  const payload = buildPDFPayload();
 
  // Write payload to a known path via the platform data channel
  // We use a hidden form POST to trigger the Python script server-side
  // Since this runs as an HTML widget, we encode the payload as base64
  // and use the claude_pdf_bridge endpoint (injected by the platform)
  status.textContent = 'Sending to PDF generator…';
 
  try {
    // Try the platform bridge endpoint first
    const resp = await fetch('/claude_pdf_bridge', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload),
    });
 
    if (resp.ok) {
      const blob = await resp.blob();
      triggerDownload(blob, getFilename(payload));
      status.textContent = '✓ PDF generated successfully!';
      btn.textContent = '✓ Done';
      setTimeout(() => { btn.disabled = false; btn.textContent = 'Generate PDF'; }, 3000);
      return;
    }
  } catch(e) { /* platform bridge not available, fallback below */ }
 
  // Fallback: encode payload and provide download instructions
  const payloadJson = JSON.stringify(payload, null, 2);
  const encoded = btoa(unescape(encodeURIComponent(payloadJson)));
 
  // Create a downloadable JSON file as the data package
  const jsonBlob = new Blob([payloadJson], { type: 'application/json' });
  const jsonUrl = URL.createObjectURL(jsonBlob);
  const fname = getFilename(payload).replace('.pdf','.json');
 
  status.innerHTML = `
    <div style="background:var(--bg);border:1px solid var(--border);border-radius:6px;padding:10px;font-size:11px;">
      <div style="font-weight:600;color:var(--navy);margin-bottom:5px">📦 PDF Data Package Ready</div>
      <div style="color:var(--text-muted);margin-bottom:8px">Download the data file then run:<br>
      <code style="background:white;padding:2px 6px;border-radius:3px;font-size:10.5px;border:1px solid var(--border)">python3 /home/claude/pdf_gen.py ${fname} output.pdf</code></div>
      <a href="${jsonUrl}" download="${fname}" style="display:inline-block;background:var(--navy);color:white;padding:5px 12px;border-radius:4px;font-size:11px;text-decoration:none;font-weight:500">⬇ Download ${fname}</a>
    </div>`;
  btn.disabled = false;
  btn.textContent = 'Generate PDF';
}
 
function getFilename(payload) {
  const client = payload.preparedFor ? payload.preparedFor.replace(/\s+/g,'_') + '_' : '';
  const date = new Date().toISOString().slice(0,10);
  return `Havenbrook_${client}Fund_Report_${date}.pdf`;
}
 
function triggerDownload(blob, filename) {
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href = url; a.download = filename; a.click();
  URL.revokeObjectURL(url);
}
 
